{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/(sitemap.xml|robots.txt|llms.txt)",
      "destination": "/$1"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/((?!assets/|Car%20images/|Car images/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
